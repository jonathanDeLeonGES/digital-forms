# ==============================================================================
# Variables de entorno — desarrollo local
# NO usar en producción. Agregar .env.dev al .gitignore del proyecto.
# ==============================================================================

# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=dev-insecure-key-cambiar-antes-de-cualquier-despliegue

# Base de datos
# django-tenants requiere PostgreSQL; SQLite no está soportado.
#
# DB_HOST=db         → dentro del contenedor Docker (nombre del servicio compose)
# DB_HOST=localhost  → pytest directo en el host con el puerto 5432 mapeado
#
DB_NAME=sgca
DB_USER=sgca
DB_PASSWORD=sgca_dev_password
DB_HOST=db
DB_PORT=5432

# Redis — Celery / Celery Beat (Wave 4)
REDIS_URL=redis://redis:6379/0
